# Oracle / Docker backend runtime defaults

# Host bind mount for exported text artifacts.
# Example on Oracle Ubuntu:
#   /srv/meeting-notes/outputs
MN_EXPORTS_HOST_DIR=./outputs

# Bind the backend only to localhost on the Oracle host so nginx can reverse proxy it.
MN_BACKEND_HOST_PORT=18000

# faster-whisper runtime
MN_MODEL_SIZE=small
MN_DEVICE=cpu
MN_COMPUTE_TYPE=int8
MN_LANGUAGE=en
MN_TRANSCRIBE_WINDOW_MS=5000
OMP_NUM_THREADS=8

# Export storage
MN_OUTPUT_DIR=/outputs
MN_EXPORT_RETENTION_DAYS=365
MN_EXPORT_MAX_SESSIONS=200
